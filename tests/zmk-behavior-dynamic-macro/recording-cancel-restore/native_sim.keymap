#include <dt-bindings/zmk/keys.h>
#include <behaviors.dtsi>
#include <behaviors/zbdm.dtsi>
#include <dt-bindings/zmk/kscan_mock.h>
#include <dt-bindings/zmk/zbdm.h>

/ {
    keymap {
        compatible = "zmk,keymap";

        default_layer {
            bindings = <&zbdm ZBDM_RECORD 0 &kp A &kp B &zbdm ZBDM_STOP 0
                        &zbdm ZBDM_CANCEL 0 &zbdm ZBDM_PLAY 0>;
        };
    };
};

&kscan {
    rows = <1>;
    columns = <6>;
    events = <
        ZMK_MOCK_PRESS(0,0,10) ZMK_MOCK_RELEASE(0,0,20)
        ZMK_MOCK_PRESS(0,1,30) ZMK_MOCK_RELEASE(0,1,40)
        ZMK_MOCK_PRESS(0,3,50) ZMK_MOCK_RELEASE(0,3,60)
        ZMK_MOCK_PRESS(0,0,70) ZMK_MOCK_RELEASE(0,0,80)
        ZMK_MOCK_PRESS(0,2,90) ZMK_MOCK_RELEASE(0,2,100)
        ZMK_MOCK_PRESS(0,4,110) ZMK_MOCK_RELEASE(0,4,120)
        ZMK_MOCK_PRESS(0,5,130) ZMK_MOCK_RELEASE(0,5,140)
    >;
};
