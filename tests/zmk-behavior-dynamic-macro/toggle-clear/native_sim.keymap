#include <dt-bindings/zmk/keys.h>
#include <behaviors.dtsi>
#include <behaviors/zbdm.dtsi>
#include <dt-bindings/zmk/kscan_mock.h>
#include <dt-bindings/zmk/zbdm.h>
/ {
    keymap {
        compatible = "zmk,keymap";
        default_layer {
            bindings = <&zbdm ZBDM_TOGGLE 0 &kp A &zbdm ZBDM_TOGGLE 0
                        &zbdm ZBDM_PLAY 0 &zbdm ZBDM_CLEAR 0
                        &zbdm ZBDM_PLAY 0 &kp B>;
        };
    };
};
&kscan {
    rows = <1>;
    columns = <7>;
    events = <
        ZMK_MOCK_PRESS(0,0,10) ZMK_MOCK_RELEASE(0,0,20)
        ZMK_MOCK_PRESS(0,1,30) ZMK_MOCK_RELEASE(0,1,40)
        ZMK_MOCK_PRESS(0,2,50) ZMK_MOCK_RELEASE(0,2,60)
        ZMK_MOCK_PRESS(0,3,70) ZMK_MOCK_RELEASE(0,3,80)
        ZMK_MOCK_PRESS(0,4,90) ZMK_MOCK_RELEASE(0,4,100)
        ZMK_MOCK_PRESS(0,5,110) ZMK_MOCK_RELEASE(0,5,120)
        ZMK_MOCK_PRESS(0,6,130) ZMK_MOCK_RELEASE(0,6,140)
    >;
};
